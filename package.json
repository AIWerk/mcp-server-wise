{
  "name": "@aiwerk/mcp-server-wise",
  "version": "0.1.6",
  "description": "Wise (TransferWise) Personal API MCP server \u2014 read-only: profiles, balances, rates, transfers, recipients",
  "type": "module",
  "main": "dist/src/server.js",
  "bin": {
    "mcp-server-wise": "dist/src/server.js"
  },
  "scripts": {
    "gen-version": "node scripts/gen-version.mjs",
    "prebuild": "npm run gen-version",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "predev": "npm run gen-version",
    "dev": "tsc --watch",
    "pretest": "npm run gen-version",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "wise",
    "transferwise",
    "fintech",
    "payments",
    "currency"
  ],
  "author": "AIWerk <kontakt@aiwerk.ch>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AIWerk/mcp-server-wise.git"
  },
  "homepage": "https://aiwerkmcp.com",
  "bugs": {
    "url": "https://github.com/AIWerk/mcp-server-wise/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.1"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ]
}
